      "States": [
        {
          "Image": "icons/cycle_radio",
          "Title": "",
          "ShowTitle": true
        }
      ],
      "Controllers": [
        "Encoder"
      ],
      "Encoder": {
        "layout": "$X1",
        "TriggerDescription": {
          "Rotate": "Rotate to select radio channel",
          "Push": "Push to toggle radio mute",
          "Touch": "Tap to cycle channel"
        }
      },
      "SupportedInMultiActions": false,
      "Tooltip": "Rotate to cycle through radio channels, press to mute radio"
