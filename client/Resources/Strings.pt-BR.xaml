    <sys:String x:Key="StatusMuted">MUTADO</sys:String>
    <sys:String x:Key="StatusActive">ATIVO</sys:String>
    <sys:String x:Key="PanelMuteStatus">Status do Mudo dos Canais</sys:String>
    <sys:String x:Key="TableHeaderChannel">Canal</sys:String>
    <sys:String x:Key="TableHeaderMicrophone">Microfone</sys:String>
    <sys:String x:Key="TableHeaderAudio">Áudio</sys:String>
    <sys:String x:Key="ChannelProximity">Proximidade</sys:String>
    <sys:String x:Key="ChannelRadio">Rádio</sys:String>
    <sys:String x:Key="ChannelProfile">Perfil</sys:String>
    
    <!-- Helmet States -->
    <sys:String x:Key="HelmetEquipped">EQUIPADO</sys:String>
    <sys:String x:Key="HelmetUnequipped">DESEQUIPADO</sys:String>

    <!-- Main Buttons -->
    <sys:String x:Key="BtnConnect">Conectar</sys:String>
