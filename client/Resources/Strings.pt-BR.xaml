    <!-- Configurações: Audio Extra -->
    <sys:String x:Key="LblEnableRadioDegradation">Habilitar degradação de rádio baseada em distância</sys:String>
    <sys:String x:Key="LblEnablePttChimes">Habilitar cliques de microfone e caudas de silenciamento</sys:String>
    <sys:String x:Key="LblEnableEnvironmentalAcoustics">Ativar acústica ambiental (oclusão e reverberação)</sys:String>

    <!-- Configurações: Overlay -->
    <sys:String x:Key="TabOverlay">Overlay</sys:String>
    <sys:String x:Key="LblEnableOverlay">Habilitar HUD de Overlay</sys:String>
    <sys:String x:Key="LblOverlayPosition">Canto do Overlay</sys:String>
    <sys:String x:Key="OptTopLeft">Superior Esquerdo</sys:String>
    <sys:String x:Key="OptTopCenter">Superior Centro</sys:String>
    <sys:String x:Key="OptTopRight">Superior Direito</sys:String>
    <sys:String x:Key="OptBottomLeft">Inferior Esquerdo</sys:String>
    <sys:String x:Key="OptBottomCenter">Inferior Centro</sys:String>
    <sys:String x:Key="OptBottomRight">Inferior Direito</sys:String>
    <sys:String x:Key="LblEnableDiscordRpc">Habilitar Discord Rich Presence</sys:String>
    <sys:String x:Key="LblOverlayCapabilities">Recursos do Overlay</sys:String>
    <sys:String x:Key="LblOverlayCapabilitiesDesc">O overlay HUD é totalmente compatível com Vulkan e DirectX quando o Star Citizen é executado em modo "Janela sem Bordas". Exibe o status da conexão VoIP no jogo, a frequência de rádio ativa e os indicadores de fala em tempo real sem se injetar no código do jogo ou arriscar banimentos.</sys:String>

