    <sys:String x:Key="TitleInvalidServerAddress">Endereço de Servidor Inválido</sys:String>

    <!-- Avisos de conexão -->
    <sys:String x:Key="WarningGrtprNoPath">O Leitor Game.log (GRTPR) está ativado, mas o caminho do arquivo Game.log não está definido. Por favor, preencha o caminho do Game.log do Star Citizen na guia de configurações Geral antes de tentar se conectar ao servidor.</sys:String>
    <sys:String x:Key="TitleWarning">Aviso</sys:String>
