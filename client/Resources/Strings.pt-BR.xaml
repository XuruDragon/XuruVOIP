    <sys:String x:Key="TabAudio">Áudio</sys:String>
    <sys:String x:Key="TabHotkeys">Atalhos</sys:String>

    <!-- Settings: Connection -->
    <sys:String x:Key="LblServerAddress">Endereço do Servidor</sys:String>
    <sys:String x:Key="LblPosPort">Porta do Servidor de Posição</sys:String>
    <sys:String x:Key="LblAudioPort">Porta do Servidor de Áudio</sys:String>
    <sys:String x:Key="LblUsername">Nome de Usuário</sys:String>
    <sys:String x:Key="LblUserPassword">Senha do Usuário</sys:String>
    <sys:String x:Key="LblServerPassword">Senha do Servidor</sys:String>
    <sys:String x:Key="LblHwid">ID de Hardware (HWID — gerado auto.)</sys:String>
