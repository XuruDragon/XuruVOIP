    <sys:String x:Key="LblGameLogPath">Caminho do Game.log do Star Citizen (Opcional)</sys:String>

    <!-- Settings: OCR -->
    <sys:String x:Key="LblPosSource">Fonte de Rastreamento de Posição</sys:String>
    <sys:String x:Key="OptOcr">Leitor de Tela OCR</sys:String>
    <sys:String x:Key="OptGrtpr">Leitor de Game.log (GRTPR)</sys:String>
    <sys:String x:Key="LblGrtprActive">Leitor de Game.log (GRTPR) Ativo</sys:String>
    <sys:String x:Key="LblGrtprDesc">As coordenadas de posição serão lidas diretamente do arquivo Game.log do Star Citizen. Isso exige que o caminho do Game.log seja preenchido na guia de configurações Geral, e que a função de depuração no jogo "r_DisplayInfo 1" (ou 3) ou "r_DisplaySessionInfo = 3" (ou 1) esteja ativada (no user.cfg ou no console do jogo). O OCR Tesseract é completamente desativado para economizar recursos do sistema.</sys:String>
    <sys:String x:Key="LblMonitor">Monitor</sys:String>
    <sys:String x:Key="LblOcrInterval">Intervalo do OCR (ms)</sys:String>
    <sys:String x:Key="BtnDefineRegion">📐  Definir Região de Escaneamento</sys:String>
    <sys:String x:Key="LblLastOcrOutput">Último texto do OCR:</sys:String>
    <sys:String x:Key="LblCurrentRegion">Região atual:</sys:String>
    <sys:String x:Key="OcrNoData">(sem dados ainda)</sys:String>
    <sys:String x:Key="OcrWaiting">Aguardando SC...</sys:String>

    <!-- Settings: Audio -->
    <sys:String x:Key="LblEnableSpatialAudio">Ativar áudio espacial 3D</sys:String>
    <sys:String x:Key="LblInputDevice">Dispositivo de Entrada (Microfone)</sys:String>
    <sys:String x:Key="LblInputGain">Ganho de Entrada: </sys:String>
