<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Title Bar -->
    <sys:String x:Key="TitleMain">XuruVoip</sys:String>
    <sys:String x:Key="TooltipSettings">Configurações</sys:String>

    <!-- Main Window Panels -->
    <sys:String x:Key="PanelStatus">Status</sys:String>
    <sys:String x:Key="PanelMicrophone">Microphone</sys:String>
