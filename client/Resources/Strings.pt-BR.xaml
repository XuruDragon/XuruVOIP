    <sys:String x:Key="LblVadSens">Sensibilidade do VAD</sys:String>
    <sys:String x:Key="LblSensLow">Baixa</sys:String>
    <sys:String x:Key="LblSensHigh">Alta</sys:String>
    <sys:String x:Key="LblRecordInstruction">Clique no campo e pressione qualquer tecla para gravar</sys:String>
    <sys:String x:Key="LblRecordInstructionMulti">Clique em um campo e pressione qualquer tecla para gravar.</sys:String>

    <!-- Settings: Hotkeys -->
    <sys:String x:Key="LblPttProximity">Tecla PTT Proximidade</sys:String>
    <sys:String x:Key="LblPttRadio">Tecla PTT Rádio</sys:String>
    <sys:String x:Key="LblPttProfile">Tecla PTT Perfil</sys:String>
