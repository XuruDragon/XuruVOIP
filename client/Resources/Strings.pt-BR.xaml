    <sys:String x:Key="PanelRadioChannel">Canal de Rádio Ativo</sys:String>
    <sys:String x:Key="PanelHelmet">Status do Capacete</sys:String>
    <sys:String x:Key="FooterText">Cliente XuruVoip · VOIP do Star Citizen</sys:String>

    <!-- Status States -->
    <sys:String x:Key="StatusDisconnected">Desconectado</sys:String>
    <sys:String x:Key="StatusConnecting">Conectando...</sys:String>
    <sys:String x:Key="StatusConnected">Conectado</sys:String>
    <sys:String x:Key="StatusConnectionFailed">Falha na conexão: {0}</sys:String>
