<Window x:Class="XuruVoipClient.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XuruVoip"
        Width="400" Height="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Icon="pack://application:,,,/XuruVoipClient;component/Resources/logo.png">

    <Window.Resources>
        <Storyboard x:Key="ProgressAnim">
            <DoubleAnimation Storyboard.TargetName="ProgressBar"
                             Storyboard.TargetProperty="Value"
                             From="0" To="100" Duration="0:0:5"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource ProgressAnim}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="16" Background="{DynamicResource BgSurface}"
            BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Center Content -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
                <!-- Logo Image -->
                <Image Source="pack://application:,,,/XuruVoipClient;component/Resources/logo.png"
                       Width="300" Height="300" Margin="0,0,0,4">
                    <Image.Effect>
                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                    </Image.Effect>
                </Image>
                
                <!-- Title -->
                <TextBlock Text="XuruVoip" Foreground="{StaticResource TextPrimary}"
                           FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                
                <!-- Subtitle / Status -->
                <TextBlock Text="Initializing Star Citizen VoIP..." Foreground="{StaticResource TextSecondary}"
                           FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
 
            <!-- Progress Bar at bottom -->
            <StackPanel Grid.Row="1" Margin="30,0,30,24">
                <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" Value="0"
                             Background="{DynamicResource BgDeep}" Foreground="{DynamicResource Accent}"
                             BorderThickness="0">
                    <ProgressBar.Template>
                        <ControlTemplate TargetType="ProgressBar">
                            <Grid x:Name="TemplateRoot">
                                <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="2" Height="4"/>
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="2" Height="4" HorizontalAlignment="Left"/>
                            </Grid>
                        </ControlTemplate>
                    </ProgressBar.Template>
                </ProgressBar>
            </StackPanel>
        </Grid>
    </Border>
</Window>
