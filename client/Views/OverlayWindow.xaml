<Window x:Class="XuruVoipClient.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XuruVoip HUD Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Grid>
        <!-- The HUD card container positioned in a specific corner -->
        <Border x:Name="HudPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20"
                Padding="16,12"
                CornerRadius="12"
                Background="#B80E1116"
                BorderThickness="1"
                BorderBrush="#30FFFFFF"
                MinWidth="180">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel Orientation="Vertical">
                <!-- Header: Connection status -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Status dot -->
                    <Ellipse x:Name="StatusDot" Grid.Column="0" Width="8" Height="8"
                             Fill="#FF4E6A" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <BlurEffect Radius="3"/>
                        </Ellipse.Effect>
                    </Ellipse>

                    <!-- Connection text / Channel Name -->
                    <TextBlock x:Name="TxtStatus" Grid.Column="1"
                               Text="Disconnected"
                               Foreground="#FFB0B3B8"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <TextBlock x:Name="TxtIntercomStatus"
                           Text=""
                           Foreground="#FFFF9800"
                           FontSize="10"
                           FontWeight="Bold"
                           Margin="0,0,0,6"
                           Visibility="Collapsed"/>

                <Separator Background="#20FFFFFF" Margin="0,0,0,8" Height="1"/>

                <!-- Active Speakers List -->
                <TextBlock x:Name="TxtSpeakersHeader" 
                           Text="ACTIVE SPEAKERS" 
                           Foreground="#80FFFFFF" 
                           FontSize="9" 
                           FontWeight="Bold" 
                           Margin="0,0,0,6"/>

                <ItemsControl x:Name="LstSpeakers" Margin="0,0,0,2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                <!-- Audio transmitting soundwave indicator / icon -->
                                <Path Fill="#FF3DDB85" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,8,0"
                                      Data="M 2 5 L 2 11 L 4 11 L 7 14 L 7 2 L 4 5 Z M 9 5.5 A 4 4 0 0 1 9 10.5 M 11 3.5 A 7 7 0 0 1 11 12.5"/>
                                <TextBlock Text="{Binding}" 
                                           Foreground="#FFFFFFFF" 
                                           FontSize="12" 
                                           FontWeight="SemiBold" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="TxtNoSpeakers" 
                           Text="No Transmissions" 
                           Foreground="#50FFFFFF" 
                           FontSize="11" 
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Tactical Mini-Radar (Top Right corner by default) -->
        <Border x:Name="RadarPanel"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20"
                Width="180"
                Height="180"
                CornerRadius="90"
                Background="#B80E1116"
                BorderThickness="2"
                BorderBrush="#803DDB85">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <!-- Compass / Orientation ticks -->
                <Ellipse Width="160" Height="160" Stroke="#203DDB85" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Ellipse Width="80" Height="80" Stroke="#103DDB85" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Line X1="80" Y1="0" X2="80" Y2="160" Stroke="#153DDB85" StrokeThickness="0.5"/>
                <Line X1="0" Y1="80" X2="160" Y2="80" Stroke="#153DDB85" StrokeThickness="0.5"/>
                
                <!-- Range Text indicator -->
                <TextBlock x:Name="TxtRadarRange" Text="50m" Foreground="#803DDB85" FontSize="9" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0"/>

                <!-- Dynamic Blip Canvas -->
                <Canvas x:Name="RadarCanvas" Width="160" Height="160" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Real-time HUD Subtitles / Captions (Bottom Center) -->
        <ItemsControl x:Name="LstCaptions"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom"
                      Margin="0,0,0,100"
                      MaxWidth="600">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#D80E1116" 
                            CornerRadius="6" 
                            Padding="10,6" 
                            Margin="0,3"
                            BorderThickness="1" 
                            BorderBrush="#15FFFFFF"
                            HorizontalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- Channel/Frequency indicator -->
                            <TextBlock Text="{Binding ChannelTag}" 
                                       Foreground="{Binding ChannelBrush}" 
                                       FontWeight="Bold" 
                                       FontSize="11" 
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <!-- Speaking Player Name -->
                            <TextBlock Text="{Binding SpeakerName}" 
                                       Foreground="#FFB0B3B8" 
                                       FontWeight="SemiBold" 
                                       FontSize="11" 
                                       Margin="0,0,5,0"
                                       VerticalAlignment="Center"/>
                            <!-- Subtitle text content -->
                            <TextBlock Text="{Binding Text}" 
                                       Foreground="#FFFFFFFF" 
                                       FontSize="11.5" 
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
